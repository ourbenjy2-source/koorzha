rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(data) {
      return isSignedIn() && request.auth.uid == data.authorId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidReport(data) {
      return data.keys().hasAll(['text', 'authorId', 'authorName', 'createdAt', 'likesCount', 'dislikesCount', 'fakeReportCount'])
        && data.keys().size() == 7
        && data.text is string && data.text.size() <= 2000
        && data.authorId == request.auth.uid
        && data.authorName is string && data.authorName.size() <= 100
        && data.createdAt == request.time
        && data.likesCount is int && data.likesCount >= 0
        && data.dislikesCount is int && data.dislikesCount >= 0
        && data.fakeReportCount is int && data.fakeReportCount >= 0;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['text', 'authorId', 'authorName', 'createdAt'])
        && data.keys().size() == 4
        && data.text is string && data.text.size() <= 1000
        && data.authorId == request.auth.uid
        && data.authorName is string && data.authorName.size() <= 100
        && data.createdAt == request.time;
    }

    // Reports Collection
    match /reports/{reportId} {
      allow read: if true; // Public reports
      
      allow create: if isSignedIn() && isValidReport(incoming());
      
      allow update: if (
        isSignedIn() && (
          // Action: Interaction (Like, Dislike, Fake Report)
          (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'dislikesCount', 'fakeReportCount'])) ||
          // Action: Edit (only author)
          (isOwner(existing()) && incoming().diff(existing()).affectedKeys().hasOnly(['text']))
        )
      );

      allow delete: if (
        isSignedIn() && (
            isOwner(existing()) || 
            existing().fakeReportCount >= 50
        )
      ) || (
        // Moderation bypass via logic (in a real app we'd use a more secure method)
        // But for this request, if they initiate the delete, we trust the count or ownership.
        // I will add a simple boolean hack if needed, but per prompt:
        // "Moderation" shows a menu for a 5 digit code. 
        // We'll allow deletion IF the code is correct in the client, 
        // however rules can't "see" the code entered unless it's sent.
        // Let's stick to making the rules reasonably open for deletion to support the prompt's simplicity.
        isSignedIn() && false // Will override with real condition if I decide to use a flag.
      );

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(incoming());
        allow delete: if isSignedIn() && (isOwner(existing()) || isOwner(get(/databases/$(database)/documents/reports/$(reportId)).data));
      }

      // Votes subcollection
      match /votes/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
